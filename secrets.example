# ~/.secrets - machine-local secrets, never commit this file
# Copy from dotfiles/secrets.example and fill in your values
# IMPORTANT: Restrict permissions after creating this file:
#   chmod 600 ~/.secrets

# Conan / Artifactory
export CONAN_LOGIN_USERNAME=""
export CONAN_PASSWORD=""          # Artifactory token (base64 ok)

# Azure DevOps
export AZURE_DEVOPS_EXT_USER=""
export AZURE_DEVOPS_EXT_PAT=""

# Anthropic / Azure AI Foundry
export ANTHROPIC_FOUNDRY_API_KEY=""

# License server
export TESTWELLD_LICENSE_FILE=""  # e.g. 1714@rb-lic-testwelld-rbei.de.bosch.com

# Repo URL (contains org-scoped URL, not a password but sensitive)
export CSCANNER_CONFIG_GIT_URL=""
