# ~/.secrets — machine-local secrets, never commit this file
# chmod 600 ~/.secrets
#
# After editing, regenerate derived files:
#   source ~/.secrets && secrets-apply

# Conan / Artifactory
export CONAN_LOGIN_USERNAME=""
export CONAN_PASSWORD=""

# Azure DevOps
export AZURE_DEVOPS_EXT_USER=""
export AZURE_DEVOPS_EXT_PAT=""

# GitHub (used by curl/pip via .netrc; git uses gh auth git-credential)
export GITHUB_TOKEN=""

# Anthropic / Azure AI Foundry
export ANTHROPIC_FOUNDRY_API_KEY=""

# License server
export TESTWELLD_LICENSE_FILE=""  # e.g. 1714@rb-lic-testwelld-rbei.de.bosch.com
